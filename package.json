{
  "name": "oscarmb.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write .",
    "//embeddings": "Regenerates generated/embeddings.json for the RAG chatbot from data sources (career, projects, socials, etc.). Requires GOOGLE_GENERATIVE_AI_API_KEY.",
    "embeddings": "tsx scripts/generate-embeddings.ts",
    "//resume:pdf": "Renders src/components/resume/ResumeDocument.tsx to public/resume.pdf via Playwright",
    "resume:pdf": "tsx scripts/generate-resume-pdf.ts",
    "//resume": "Full resume pipeline: generate PDF and regenerate embeddings",
    "resume": "pnpm resume:pdf && pnpm embeddings",
    "test:resume-hooks": "bash scripts/test-resume-hooks.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "deploy:scan": "tsx scripts/deploy-agent/scan-failures.ts",
    "deploy:guardian": "tsx scripts/deploy-agent/guardian.ts",
    "test:deploy-agent": "tsx --test scripts/deploy-agent/*.test.ts",
    "sandcastle": "npx tsx .sandcastle/main.mts"
  },
  "dependencies": {
    "@ai-hero/sandcastle": "^0.3.0",
    "@ai-sdk/google": "^3.0.7",
    "@ai-sdk/openai": "^3.0.2",
    "@ai-sdk/react": "^3.0.6",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.0",
    "@sentry/nextjs": "^10.38.0",
    "ai": "^6.0.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "framer-motion": "^12.23.12",
    "gray-matter": "^4.0.3",
    "langchain": "^0.3.2",
    "lucide-react": "^0.441.0",
    "mermaid": "^10.9.1",
    "next": "^16",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "resend": "^4.0.0",
    "sonner": "^1.5.0",
    "sugar-high": "^0.7.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
